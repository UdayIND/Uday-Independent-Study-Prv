# =============================================================================
# SENTINEL-RL .gitignore
# =============================================================================

# --- Data & Models (large files, not tracked) ---
data/
experiments/checkpoints/
experiments/results/

# --- Reports (generated output) ---
reports/runs/
reports/benchmark/
reports/ablation/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
MANIFEST

# --- Virtual environments ---
venv/
env/
.venv/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- Logs ---
*.log
experiments/logs/

# --- Environment ---
.env
.env.local

# --- OS ---
.DS_Store
Thumbs.db

# --- Temporary ---
tmp/
temp/
*.tmp

# --- Jupyter ---
.ipynb_checkpoints/

# --- Paper source (do not commit to repo) ---
extracted_paper.txt
*.pdf
