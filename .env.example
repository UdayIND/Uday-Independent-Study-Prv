# =========================================
# SOC-Informed Discovery: Environment Config
# =========================================

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development

# --- Neo4j Graph Database ---
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_secure_password

# --- Kafka Ingestion ---
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=network_events
KAFKA_GROUP_ID=sentinel_ingestion_group

# --- Model Paths ---
MODEL_SAVE_DIR=data/models
MODEL_VERSION=latest

# --- Logging ---
LOG_LEVEL=INFO
