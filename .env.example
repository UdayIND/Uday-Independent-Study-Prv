# =========================================
# SENTINEL-RL: Environment Configuration
# =========================================
# Copy this to .env and fill in your values.

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Neo4j Graph Database ---
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_secure_password

# --- Kafka (optional, only for live streaming ingestion) ---
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=network_events
KAFKA_GROUP_ID=sentinel_ingestion_group

# --- LLM (optional, for Triage/Critic agent narratives) ---
OPENAI_API_KEY=sk-your-openai-api-key

# --- Model Storage ---
MODEL_SAVE_DIR=data/models

# --- Logging ---
LOG_LEVEL=INFO
